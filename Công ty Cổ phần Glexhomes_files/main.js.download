    })
    $("#SendContact input").change(function () {
        if ($(this).val().length > 0) {
            $(this).next(".place").hide();
        }
        else {
            $(this).next(".place").show();
        }
    });
    $("#SendContact2 input").change(function () {
        if ($(this).val().length > 0) {
            $(this).next(".place").hide();
